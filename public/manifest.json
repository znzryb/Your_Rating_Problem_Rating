{
  "manifest_version": 3,
  "name": "Your Rating · Problem Rating",
  "version": "0.2.0",
  "description": "Codeforces: Carrot-style reverse-Elo problem rating, derived from public contest.status submissions.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.codeforces.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.codeforces.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
